# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/expensemanager?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_this_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# App
PORT=3000
NODE_ENV=development
